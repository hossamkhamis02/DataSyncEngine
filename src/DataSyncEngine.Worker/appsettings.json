{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning",
      "Hangfire": "Information"
    }
  },
  "SyncConfiguration": {
    "PageSize": 100,
    "ApiBaseUrl": "https://api.example.com/products",
    "RetryCount": 3,
    "CircuitBreakerThreshold": 5,
    "CircuitBreakerDurationSeconds": 30,
    "SyncCronExpression": "0 * * * *",
    "UseMockApi": true,
    "ConnectionString": "Server=localhost,1433;Database=DataSyncEngine;User Id=sa;Password=YourStrong!Passw0rd;TrustServerCertificate=true;"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/data-sync-engine-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  }
}
